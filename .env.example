# ─── Supabase (Fase 2: auth + base de datos) ───
# Crea un proyecto gratis en https://supabase.com y copia estos valores
# desde Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Service role: SOLO servidor. Nunca la expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── URL pública del sitio (para callbacks de auth / Stripe) ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Stripe (Fase 3: pagos) ───
# https://dashboard.stripe.com/apikeys  (usa las claves de TEST para empezar)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Se obtiene al crear el webhook (o con `stripe listen`).
STRIPE_WEBHOOK_SECRET=whsec_...
